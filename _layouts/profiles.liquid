---
layout: page
---
<div class="post">
  <article>
    {{ content }}

    {% if page.lab_directors %}
      <h2>Lab Directors</h2>
      <div class="row">
        {% for profile in page.lab_directors %}
          <div class="col-md-6 mb-4">
            <div class="card h-100">
              <div class="card-body text-center">
                {% if profile.image %}
                  {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                  <img src="{{ profile_image_path | relative_url }}" class="card-img-top mx-auto d-block mb-3" style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%;" alt="{{ profile.name }}">
                {% else %}
                  <div class="mx-auto d-block mb-3" style="width: 150px; height: 150px; background-color: #f8f9fa; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-user" style="font-size: 4rem; color: #6c757d;"></i>
                  </div>
                {% endif %}
                {% if profile.content %}
                  {% capture profile_content %}{% include_relative {{ profile.content }} %}{% endcapture %}
                  {{ profile_content | markdownify }}
                {% else %}
                  <h5 class="card-title">{{ profile.name }}</h5>
                  <p class="card-text">{{ profile.description }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if page.affiliated_researchers %}
      <h2>Affiliated Researchers</h2>
